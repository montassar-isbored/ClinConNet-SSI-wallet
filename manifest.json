{
  "manifest_version": 3,
  "name": "ClinConNet Veramo Wallet",
  "version": "0.1.0",
  "description": "Veramo-based SSI Wallet for ClinConNet PoC.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://localhost:3000/*",
    "http://localhost:3002/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}